# Variables d'environnement (copier en .env.local pour le dev).
# Toutes PUBLIQUES (préfixe NEXT_PUBLIC_) — ne jamais y mettre de secret.

# URL absolue du site (metadataBase / OG / canonical). Défaut dev : http://localhost:3000
# NEXT_PUBLIC_SITE_URL=https://omniventus.com/gelateria

# Préfixe de sous-chemin GitHub Pages ("" pour un domaine custom).
# NEXT_PUBLIC_BASE_PATH=/gelateria

# Google Analytics 4 — Measurement ID (format G-XXXXXXXXXX).
# Non défini → GA4 dormant (aucun cookie, aucune requête tierce).
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
